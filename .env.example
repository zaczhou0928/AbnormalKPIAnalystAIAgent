# LLM Provider Configuration
# Leave empty to use mock mode (no API key required)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Application Settings
LLM_MODE=mock  # "mock" or "openai"
LOG_LEVEL=INFO
WAREHOUSE_PATH=data/generated/warehouse.duckdb
MAX_SQL_ROWS=10000
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.6
HUMAN_REVIEW_AUTO_APPROVE=true
